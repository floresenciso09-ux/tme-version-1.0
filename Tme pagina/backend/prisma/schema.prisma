generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleType {
  ADMIN
  EMPLOYEE
  CLIENT
  GUEST
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      RoleType @default(CLIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile?
}

model Profile {
  id        String @id @default(cuid())
  user      User   @relation(fields: [userId], references: [id])
  userId    String @unique
  bio       String?
  phone     String?
  company   String?
  createdAt DateTime @default(now())
}

model Client {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  company   String?
  phone     String?
  createdAt DateTime @default(now())
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  price       Float
  inventory   Int      @default(0)
  category    String
  createdAt   DateTime @default(now())
}

model Service {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  status      String
  createdAt   DateTime @default(now())
}

model Order {
  id         String   @id @default(cuid())
  client     Client?  @relation(fields: [clientId], references: [id])
  clientId   String?
  status     String   @default("PENDING")
  total      Float
  createdAt  DateTime @default(now())
  orderItems OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   String
  product   Product @relation(fields: [productId], references: [id])
  productId String
  quantity  Int
  price     Float
}

model Quote {
  id          String   @id @default(cuid())
  clientName  String
  email       String
  request     String
  status      String   @default("NEW")
  createdAt   DateTime @default(now())
}

model Project {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String
  status      String
  technologies String
  createdAt   DateTime @default(now())
}

model News {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  publishedAt DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Setting {
  id     String @id @default(cuid())
  key    String @unique
  value  String
}

model Log {
  id        String   @id @default(cuid())
  level     String
  message   String
  meta      String?
  createdAt DateTime @default(now())
}
